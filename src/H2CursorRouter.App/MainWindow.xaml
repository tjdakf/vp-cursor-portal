<Window x:Class="H2CursorRouter.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="vp-cursor-portal"
        Width="1500"
        Height="810"
        MinWidth="1360"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Loaded="OnLoaded"
        Closing="OnClosing">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                            ResizeBorderThickness="8"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource ShellBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0">
                    <Border Width="10" Height="10" CornerRadius="3" Background="{StaticResource AccentBrush}" Margin="0,0,10,0" />
                    <TextBlock Text="vp-cursor-portal" Foreground="#E5E7EB" FontSize="13" FontWeight="SemiBold" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Content="-" Click="MinimizeButton_OnClick" Style="{StaticResource WindowCaptionButtonStyle}" />
                    <Button Content="□" Click="MaximizeButton_OnClick" Style="{StaticResource WindowCaptionButtonStyle}" />
                    <Button Content="×" Click="CloseButton_OnClick" Style="{StaticResource WindowCloseButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="{StaticResource ShellBrush}" Padding="22,4,22,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Cursor routing console" Foreground="White" FontSize="20" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding RuntimeStatus}" Foreground="{StaticResource ShellMutedBrush}" Margin="0,3,0,0" />
                </StackPanel>
                <Button Grid.Column="1" Content="Validate" Command="{Binding ValidateConfigurationCommand}" Style="{StaticResource ToolbarButtonStyle}" />
                <Button Grid.Column="2" Content="Save Config" Command="{Binding SaveConfigurationCommand}" Style="{StaticResource ToolbarPrimaryButtonStyle}" />
                <Button Grid.Column="3" Content="Refresh Displays" Command="{Binding RefreshDiagnosticsCommand}" Style="{StaticResource ToolbarButtonStyle}" />
                <Button Grid.Column="4" Content="Emergency Unlock" Command="{Binding EmergencyUnlockCommand}" Style="{StaticResource DangerButtonStyle}" Margin="0" />
            </Grid>
        </Border>

        <TabControl x:Name="MainTabs" Grid.Row="2" Margin="0" TabStripPlacement="Left" SelectionChanged="MainTabs_OnSelectionChanged">
            <TabItem Header="Dashboard">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="760" />
                            <ColumnDefinition Width="380" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.RowSpan="2" Style="{StaticResource CardStyle}" MinHeight="650">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                                    <TextBlock Text="Profiles" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                                </StackPanel>
                                <ItemsControl ItemsSource="{Binding DashboardProfiles}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource ProfileCardStyle}" Margin="0,0,0,8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="112" />
                                                        <ColumnDefinition Width="250" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="68" />
                                                        <ColumnDefinition Width="68" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Hotkey}" Foreground="{StaticResource AccentBrush}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="{StaticResource TextBrush}" FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap" VerticalAlignment="Center" Margin="10,0" />
                                                    <TextBlock Grid.Column="2" Text="{Binding Description}" Style="{StaticResource MutedTextStyle}" FontSize="13" TextWrapping="Wrap" VerticalAlignment="Center" Margin="10,0" />
                                                    <Button Grid.Column="3"
                                                            Content="Run"
                                                            Command="{Binding DataContext.ExecuteProfileCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"
                                                            VerticalAlignment="Center"
                                                            MinHeight="30"
                                                            Padding="10,4"
                                                            Margin="8,0,0,0" />
                                                    <Button Grid.Column="4"
                                                            Content="Edit"
                                                            Tag="{Binding}"
                                                            Click="EditProfileButton_OnClick"
                                                            Style="{StaticResource SecondaryButtonStyle}"
                                                            VerticalAlignment="Center"
                                                            MinHeight="30"
                                                            Padding="10,4"
                                                            Margin="8,0,0,0" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </DockPanel>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Runtime" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                                <UniformGrid Columns="1" Margin="0,16,0,0">
                                    <StackPanel Margin="0,0,12,14">
                                        <TextBlock Text="Routing" Style="{StaticResource MutedTextStyle}" />
                                        <TextBlock Text="{Binding RoutingStateText}" FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,12,14">
                                        <TextBlock Text="Layout" Style="{StaticResource MutedTextStyle}" />
                                        <TextBlock Text="{Binding ActiveLayoutName}" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="H2 Connection" Style="{StaticResource MutedTextStyle}" />
                                        <Grid Margin="0,3,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Ellipse Style="{StaticResource ConnectionIndicatorStyle}" />
                                            <TextBlock Grid.Column="1" Text="{Binding H2ConnectionStatus}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap" />
                                        </Grid>
                                    </StackPanel>
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <Grid Grid.Column="1" Grid.Row="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="Safety" Style="{StaticResource SectionTitleStyle}" />
                                    <Button Content="Emergency Unlock" Command="{Binding EmergencyUnlockCommand}" Style="{StaticResource DangerButtonStyle}" Margin="0,0,0,8" />
                                    <Button Content="Stop Routing" Command="{Binding StopRoutingCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0" />
                                    <TextBlock Text="{Binding LastRoutingEvent}" Style="{StaticResource MutedTextStyle}" Margin="0,14,0,0" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Startup" Style="{StaticResource SectionTitleStyle}" />
                                    <CheckBox Content="Start with Windows" IsChecked="{Binding StartWithWindows}" Margin="0,2,0,0" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Grid.ColumnSpan="2" Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Runtime Log" Style="{StaticResource SectionTitleStyle}" />
                                <ListBox ItemsSource="{Binding Logs}" Height="220" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Layouts">
                <Grid Margin="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Layout Workflow" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="Detect monitors, choose visible zones, arrange the H2 visual canvas, apply layout, validate, then save." Style="{StaticResource MutedTextStyle}" Margin="0,0,0,10" />
                                <Button Content="Create Layout From Detected Monitors" Command="{Binding CreateLayoutFromMonitorsCommand}" Margin="0,0,0,8" />
                                <Button Content="Match Windows Monitor Coordinates" Command="{Binding ApplyDetectedMonitorCoordinatesCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,8" />
                                <Button Content="Apply Canvas And Generate Portals" Command="{Binding ApplyCanvasLayoutCommand}" Margin="0,0,0,8" />
                                <Button Content="Validate" Command="{Binding ValidateConfigurationCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Layouts" Style="{StaticResource SectionTitleStyle}" />
                                <DataGrid ItemsSource="{Binding Layouts}" SelectedItem="{Binding SelectedLayout}" AutoGenerateColumns="False" IsReadOnly="False" Height="170">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                                        <DataGridTextColumn Header="Internal Id" Binding="{Binding Id}" Width="130" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                                    <Button Content="Add" Command="{Binding AddLayoutCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                                    <Button Content="Remove" Command="{Binding RemoveLayoutCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardStyle}" Margin="0">
                            <StackPanel>
                                <TextBlock Text="Selected Zones" Style="{StaticResource SectionTitleStyle}" />
                                <ItemsControl ItemsSource="{Binding SelectedLayoutZones}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource InsetCardStyle}" Margin="0,0,0,8">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding Id, StringFormat={}Internal key: {0}}" Style="{StaticResource MutedTextStyle}" />
                                                    <CheckBox Content="Visible in H2 layout" IsChecked="{Binding IsVisible}" Margin="0,6,0,0" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="0">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                                <TextBlock Text="H2 Visual Canvas" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="Drag blocks to match the visible H2 output. Resize from the lower-right handle. Snap aligns to monitor edges and 120px grid." Style="{StaticResource MutedTextStyle}" />
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <TextBlock Text="Scale" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <Slider Width="150" Minimum="0.08" Maximum="0.5" TickFrequency="0.02" IsSnapToTickEnabled="True" Value="{Binding LayoutPreviewScale}" />
                                    <TextBlock Text="{Binding LayoutPreviewScale, StringFormat={}{0:P0}}" VerticalAlignment="Center" Margin="8,0,18,0" />
                                    <TextBlock Text="Snap 120px" Style="{StaticResource MutedTextStyle}" VerticalAlignment="Center" />
                                </StackPanel>
                            </StackPanel>
                            <Border BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Background="{StaticResource PanelAltBrush}" CornerRadius="10" Padding="10">
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding SelectedLayoutZones}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <Canvas Width="{Binding DataContext.LayoutPreviewCanvasWidth, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        Height="{Binding DataContext.LayoutPreviewCanvasHeight, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        Background="{StaticResource PanelElevatedBrush}">
                                                    <Canvas.LayoutTransform>
                                                        <ScaleTransform ScaleX="{Binding DataContext.LayoutPreviewScale, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                        ScaleY="{Binding DataContext.LayoutPreviewScale, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                                                    </Canvas.LayoutTransform>
                                                </Canvas>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Setter Property="Canvas.Left" Value="{Binding VisualLeft}" />
                                                <Setter Property="Canvas.Top" Value="{Binding VisualTop}" />
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Width="{Binding VisualWidth}" Height="{Binding VisualHeight}">
                                                    <primitives:Thumb DragDelta="ZoneMoveThumb_OnDragDelta">
                                                        <primitives:Thumb.Template>
                                                            <ControlTemplate TargetType="primitives:Thumb">
                                                                <Border Background="{StaticResource AccentSoftBrush}" BorderBrush="{StaticResource AccentBrush}" BorderThickness="8">
                                                                    <StackPanel Margin="24">
                                                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" FontSize="64" TextWrapping="Wrap" />
                                                                        <TextBlock Text="{Binding Id}" Foreground="{StaticResource MutedTextBrush}" FontSize="40" />
                                                                    </StackPanel>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </primitives:Thumb.Template>
                                                    </primitives:Thumb>
                                                    <primitives:Thumb Width="96" Height="96" HorizontalAlignment="Right" VerticalAlignment="Bottom" Cursor="SizeNWSE" DragDelta="ZoneResizeThumb_OnDragDelta">
                                                        <primitives:Thumb.Template>
                                                            <ControlTemplate TargetType="primitives:Thumb">
                                                                <Border Background="{StaticResource AccentBrush}" />
                                                            </ControlTemplate>
                                                        </primitives:Thumb.Template>
                                                    </primitives:Thumb>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Profiles">
                <Grid Margin="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                        <DockPanel>
                            <TextBlock Text="Search" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBox Text="{Binding ProfileFilter, UpdateSourceTrigger=PropertyChanged}" MinWidth="260" />
                        </DockPanel>
                    </Border>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding FilteredProfiles}" SelectedItem="{Binding SelectedProfile}" AutoGenerateColumns="False" IsReadOnly="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*" />
                            <DataGridTextColumn Header="Hotkey" Binding="{Binding Hotkey}" Width="120" />
                            <DataGridTextColumn Header="Preset" Binding="{Binding PresetSummary}" Width="180" IsReadOnly="True" />
                            <DataGridTextColumn Header="Cursor Layout" Binding="{Binding CursorLayoutId}" Width="180" />
                            <DataGridTextColumn Header="Start X" Binding="{Binding StartX}" Width="80" />
                            <DataGridTextColumn Header="Start Y" Binding="{Binding StartY}" Width="80" />
                            <DataGridTextColumn Header="Post ACK Delay" Binding="{Binding PostAckDelayMs}" Width="120" />
                            <DataGridCheckBoxColumn Header="Require H2 ACK" Binding="{Binding RequireH2AckBeforeCursorLayout}" Width="120" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button Content="Add Profile" Command="{Binding AddProfileCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Content="Remove Profile" Command="{Binding RemoveProfileCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Content="Duplicate Profile" Command="{Binding DuplicateProfileCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Content="Map Selected Preset" Command="{Binding ApplySelectedPresetToProfileCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Content="Map Selected Layout" Command="{Binding ApplySelectedLayoutToProfileCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Content="Use Current Cursor" Command="{Binding SetCurrentCursorAsStartCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Content="Execute Profile" Command="{Binding ExecuteSelectedProfileCommand}" Margin="0" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="H2">
                <Grid Margin="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Style="{StaticResource CardStyle}">
                        <DockPanel>
                            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <Button Content="Add Device" Command="{Binding AddDeviceCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                                    <Button Content="Remove Device" Command="{Binding RemoveDeviceCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                                    <Button Content="Get All Presets" Command="{Binding GetAllPresetsCommand}" Margin="0" />
                                </StackPanel>
                                <TextBlock Text="Device" Style="{StaticResource SectionTitleStyle}" VerticalAlignment="Center" />
                            </DockPanel>
                            <DataGrid ItemsSource="{Binding Devices}" SelectedItem="{Binding SelectedDevice}" AutoGenerateColumns="False" IsReadOnly="False">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="" Width="42" IsReadOnly="True">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Ellipse Style="{StaticResource ConnectionIndicatorStyle}" HorizontalAlignment="Center" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Device" Binding="{Binding Name}" Width="180" />
                                    <DataGridTextColumn Header="Host" Binding="{Binding Host}" Width="160" />
                                    <DataGridTextColumn Header="Port" Binding="{Binding Port}" Width="80" />
                                    <DataGridTextColumn Header="Timeout ms" Binding="{Binding TimeoutMs}" Width="100" />
                                    <DataGridTextColumn Header="Device ID" Binding="{Binding DeviceId}" Width="100" />
                                    <DataGridTextColumn Header="Config Key" Binding="{Binding Id}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>
                    <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0">
                        <DockPanel>
                            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                                <Button DockPanel.Dock="Right" Content="Get Presets" Command="{Binding GetPresetsCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0" />
                                <TextBlock Text="Presets" Style="{StaticResource SectionTitleStyle}" VerticalAlignment="Center" />
                            </DockPanel>
                            <DataGrid ItemsSource="{Binding Presets}" SelectedItem="{Binding SelectedPreset}" AutoGenerateColumns="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Device" Binding="{Binding DeviceName}" Width="180" />
                                    <DataGridTextColumn Header="Screen ID" Binding="{Binding ScreenId}" Width="100" />
                                    <DataGridTextColumn Header="Preset" Binding="{Binding FriendlyPresetNumber}" Width="100" />
                                    <DataGridTextColumn Header="Display Name" Binding="{Binding DisplayName}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Displays">
                <Grid Margin="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,16,12">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="Refresh" Command="{Binding RefreshDiagnosticsCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0" />
                            <TextBlock Text="Displays" Style="{StaticResource SectionTitleStyle}" VerticalAlignment="Center" />
                        </DockPanel>
                    </Border>
                    <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Monitors}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas Width="{Binding DataContext.DisplayPreviewCanvasWidth, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                Height="{Binding DataContext.DisplayPreviewCanvasHeight, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                Background="{StaticResource PanelElevatedBrush}" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding PreviewLeft}" />
                                        <Setter Property="Canvas.Top" Value="{Binding PreviewTop}" />
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="{Binding PreviewWidth}"
                                                Height="{Binding PreviewHeight}"
                                                Background="{StaticResource AccentSoftBrush}"
                                                BorderBrush="{StaticResource AccentBrush}"
                                                BorderThickness="2"
                                                CornerRadius="8"
                                                Padding="12">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="*" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <DockPanel>
                                                    <TextBlock DockPanel.Dock="Right" Text="{Binding PrimaryText}" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding DeviceName}" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                                                </DockPanel>
                                                <TextBlock Grid.Row="1"
                                                           Text="{Binding BoundsText}"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           TextWrapping="Wrap"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Grid.Row="2"
                                                           Text="{Binding Width, StringFormat={}{0}px wide}"
                                                           Foreground="{StaticResource MutedTextBrush}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Advanced">
                <Grid Margin="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <GroupBox Header="Raw zones - Id is an internal config key used by portals" Margin="0,0,0,10">
                        <DockPanel Margin="8">
                            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                                <Button Content="Add Zone" Command="{Binding AddZoneCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                                <Button Content="Remove Zone" Command="{Binding RemoveZoneCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0" />
                            </StackPanel>
                            <DataGrid ItemsSource="{Binding SelectedLayoutZones}" SelectedItem="{Binding SelectedZone}" AutoGenerateColumns="True" IsReadOnly="False" />
                        </DockPanel>
                    </GroupBox>
                    <GroupBox Grid.Row="1" Header="Raw portals - FromZoneId and ToZoneId must match zone Id values" Margin="0,0,0,10">
                        <DockPanel Margin="8">
                            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                                <Button Content="Auto Portals" Command="{Binding GeneratePortalsCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                                <Button Content="Add Portal" Command="{Binding AddPortalCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                                <Button Content="Remove Portal" Command="{Binding RemovePortalCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0" />
                            </StackPanel>
                            <DataGrid ItemsSource="{Binding SelectedLayoutPortals}" SelectedItem="{Binding SelectedPortal}" AutoGenerateColumns="True" IsReadOnly="False" />
                        </DockPanel>
                    </GroupBox>
                    <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
                                <Button Content="Validate" Command="{Binding ValidateConfigurationCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                                <Button Content="Save Config" Command="{Binding SaveConfigurationCommand}" Margin="0" />
                            </StackPanel>
                            <ListBox ItemsSource="{Binding ValidationErrors}" Height="130" />
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
