<Window x:Class="H2CursorRouter.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="vp-cursor-portal"
        Width="1180"
        Height="820"
        MinWidth="980"
        MinHeight="680"
        Loaded="OnLoaded"
        Closing="OnClosing">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#1D232A" Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="vp-cursor-portal" Foreground="White" FontSize="20" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding RuntimeStatus}" Foreground="#C8D1DC" Margin="0,4,0,0" />
                </StackPanel>
                <Button Grid.Column="1" Content="Validate" Command="{Binding ValidateConfigurationCommand}" Margin="0,0,10,0" Padding="12,7" />
                <Button Grid.Column="2" Content="Save Config" Command="{Binding SaveConfigurationCommand}" Margin="0,0,10,0" Padding="12,7" />
                <Button Grid.Column="3" Content="Refresh Diagnostics" Command="{Binding RefreshDiagnosticsCommand}" Margin="0,0,10,0" Padding="12,7" />
                <Button Grid.Column="4" Content="Emergency Unlock" Command="{Binding EmergencyUnlockCommand}" Padding="12,7" Background="#A32929" Foreground="White" />
            </Grid>
        </Border>

        <TabControl Margin="12">
            <TabItem Header="H2 Device Settings">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <DataGrid ItemsSource="{Binding Devices}" SelectedItem="{Binding SelectedDevice}" AutoGenerateColumns="True" IsReadOnly="False" />
                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button Content="Add Device" Command="{Binding AddDeviceCommand}" Margin="0,0,10,0" Padding="12,7" />
                        <Button Content="Remove Device" Command="{Binding RemoveDeviceCommand}" Margin="0,0,10,0" Padding="12,7" />
                        <Button Content="Test / Get Presets" Command="{Binding GetPresetsCommand}" Padding="12,7" />
                    </StackPanel>
                </Grid>
            </TabItem>
            <TabItem Header="H2 Presets">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <DataGrid ItemsSource="{Binding Presets}" SelectedItem="{Binding SelectedPreset}" AutoGenerateColumns="True" IsReadOnly="True" />
                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button Content="Get Presets" Command="{Binding GetPresetsCommand}" Margin="0,0,10,0" Padding="12,7" />
                        <Button Content="Map Preset To Profile" Command="{Binding ApplySelectedPresetToProfileCommand}" Margin="0,0,10,0" Padding="12,7" />
                        <Button Content="Execute Profile" Command="{Binding ExecuteSelectedProfileCommand}" Padding="12,7" />
                    </StackPanel>
                </Grid>
            </TabItem>
            <TabItem Header="Monitor Diagnostics">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Cursor:" FontWeight="SemiBold" Margin="0,0,6,0" />
                        <TextBlock Text="{Binding CurrentCursorPosition}" Margin="0,0,20,0" />
                        <TextBlock Text="Zone:" FontWeight="SemiBold" Margin="0,0,6,0" />
                        <TextBlock Text="{Binding CurrentCursorZone}" />
                    </StackPanel>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Monitors}" AutoGenerateColumns="True" IsReadOnly="True" />
                </Grid>
            </TabItem>
            <TabItem Header="Cursor Layouts">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="2*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <DataGrid ItemsSource="{Binding Layouts}" SelectedItem="{Binding SelectedLayout}" AutoGenerateColumns="True" IsReadOnly="False" />
                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,10">
                        <Button Content="Add Layout" Command="{Binding AddLayoutCommand}" Margin="0,0,10,0" Padding="12,7" />
                        <Button Content="Remove Layout" Command="{Binding RemoveLayoutCommand}" Margin="0,0,10,0" Padding="12,7" />
                        <Button Content="Create From Monitors" Command="{Binding CreateLayoutFromMonitorsCommand}" Margin="0,0,10,0" Padding="12,7" />
                        <Button Content="Map Layout To Profile" Command="{Binding ApplySelectedLayoutToProfileCommand}" Padding="12,7" />
                    </StackPanel>
                    <DataGrid Grid.Row="2" ItemsSource="{Binding Zones}" SelectedItem="{Binding SelectedZone}" AutoGenerateColumns="True" IsReadOnly="False" />
                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button Content="Add Zone" Command="{Binding AddZoneCommand}" Margin="0,0,10,0" Padding="12,7" />
                        <Button Content="Remove Zone" Command="{Binding RemoveZoneCommand}" Padding="12,7" />
                    </StackPanel>
                </Grid>
            </TabItem>
            <TabItem Header="Portals">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <DataGrid ItemsSource="{Binding Portals}" SelectedItem="{Binding SelectedPortal}" AutoGenerateColumns="True" IsReadOnly="False" />
                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button Content="Add Portal" Command="{Binding AddPortalCommand}" Margin="0,0,10,0" Padding="12,7" />
                        <Button Content="Remove Portal" Command="{Binding RemovePortalCommand}" Padding="12,7" />
                    </StackPanel>
                </Grid>
            </TabItem>
            <TabItem Header="Execution Profiles">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <DataGrid ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}" AutoGenerateColumns="True" IsReadOnly="False" />
                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button Content="Add Profile" Command="{Binding AddProfileCommand}" Margin="0,0,10,0" Padding="12,7" />
                        <Button Content="Remove Profile" Command="{Binding RemoveProfileCommand}" Margin="0,0,10,0" Padding="12,7" />
                        <Button Content="Map Selected Preset" Command="{Binding ApplySelectedPresetToProfileCommand}" Margin="0,0,10,0" Padding="12,7" />
                        <Button Content="Map Selected Layout" Command="{Binding ApplySelectedLayoutToProfileCommand}" Margin="0,0,10,0" Padding="12,7" />
                        <Button Content="Execute Profile" Command="{Binding ExecuteSelectedProfileCommand}" Padding="12,7" />
                    </StackPanel>
                </Grid>
            </TabItem>
            <TabItem Header="Validation">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
                        <Button Content="Validate" Command="{Binding ValidateConfigurationCommand}" Margin="0,0,10,0" Padding="12,7" />
                        <Button Content="Save Config" Command="{Binding SaveConfigurationCommand}" Padding="12,7" />
                    </StackPanel>
                    <ListBox Grid.Row="1" ItemsSource="{Binding ValidationErrors}" />
                </Grid>
            </TabItem>
            <TabItem Header="Runtime">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <UniformGrid Columns="4" Margin="0,0,0,10">
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="Active Profile" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding ActiveProfileName}" />
                        </StackPanel>
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="Active Layout" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding ActiveLayoutId}" />
                        </StackPanel>
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="Routing Enabled" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding IsRoutingEnabled}" />
                        </StackPanel>
                        <Button Content="Stop Routing" Command="{Binding StopRoutingCommand}" Padding="12,7" />
                    </UniformGrid>
                    <ListBox Grid.Row="1" ItemsSource="{Binding Logs}" />
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
